{
  "manifest_version": 3,
  "name": "NotePin - AI Web Clipper for Notion",
  "short_name": "NotePin",
  "version": "1.0.0",
  "description": "One-click save web pages or selections to Notion. AI auto-summarizes, tags and categorizes. Supports English & Chinese.",
  "author": "klcoks",
  "homepage_url": "https://github.com/klcoks/notepin",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "NotePin - One-click save to Notion"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "https://api.deepseek.com/*",
    "https://api.notion.com/*"
  ],
  "commands": {
    "save-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Save current page to Notion"
    }
  }
}
